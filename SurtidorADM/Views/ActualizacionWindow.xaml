<Window x:Class="SurtidorADM.Views.ActualizacionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Actualización de SurtidorADM" 
        Height="360" Width="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F3F4F6"
        FontFamily="Segoe UI, Inter, Roboto">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Banner Header -->
            <RowDefinition Height="Auto"/>
            <!-- Notes / Content -->
            <RowDefinition Height="*"/>
            <!-- Progress Area (collapsible) -->
            <RowDefinition Height="Auto"/>
            <!-- Footer Actions -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 1. Banner Header -->
        <Border Grid.Row="0" Background="#1E3A8A" Padding="20,15">
            <StackPanel>
                <TextBlock Text="✨ ¡NUEVA ACTUALIZACIÓN DISPONIBLE!" FontSize="11" FontWeight="Bold" Foreground="#93C5FD" Margin="0,0,0,2"/>
                <TextBlock x:Name="TxtVersiones" Text="Versión 1.0.0 → Versión 1.1.0" FontSize="18" FontWeight="Bold" Foreground="White"/>
            </StackPanel>
        </Border>

        <!-- 2. Release Notes -->
        <Border Grid.Row="1" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="20,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="¿Qué hay de nuevo?" FontWeight="SemiBold" FontSize="13" Foreground="#111827" Margin="0,0,0,6"/>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtNovedades" Text="• Novedades de la actualización..." FontSize="12.5" Foreground="#4B5563" TextWrapping="Wrap" LineHeight="18"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- 3. Progress Area -->
        <Border x:Name="PanelProgreso" Grid.Row="2" Background="#F9FAFB" Padding="20,12" Visibility="Collapsed">
            <StackPanel>
                <TextBlock x:Name="TxtProgreso" Text="Descargando actualización... 0%" FontSize="11.5" Foreground="#4B5563" Margin="0,0,0,5"/>
                <ProgressBar x:Name="BarraProgreso" Height="10" Minimum="0" Maximum="100" Value="0" Foreground="#2563EB" Background="#E5E7EB" BorderThickness="0"/>
            </StackPanel>
        </Border>

        <!-- 4. Footer Actions -->
        <Border Grid.Row="3" Background="#F9FAFB" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock x:Name="TxtEstado" Text="Se recomienda actualizar para contar con las últimas mejoras de conciliación." 
                           VerticalAlignment="Center" FontSize="10.5" Foreground="#6B7280" TextWrapping="Wrap" Margin="0,0,10,0"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" x:Name="PanelBotones">
                    <Button Content="Recordar Luego" 
                            Click="RecordarLuego_Click"
                            Width="110" Height="34"
                            Background="Transparent" Foreground="#4B5563"
                            FontWeight="SemiBold" FontSize="12"
                            BorderBrush="#D1D5DB" BorderThickness="1"
                            Margin="0,0,10,0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    
                    <Button Content="Actualizar Ahora" 
                            Click="ActualizarAhora_Click"
                            Width="120" Height="34"
                            Background="#2563EB" Foreground="White"
                            FontWeight="SemiBold" FontSize="12"
                            BorderThickness="0" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Trigger.Setters>
                                            <Setter Property="Background" Value="#1D4ED8"/>
                                        </Trigger.Setters>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
