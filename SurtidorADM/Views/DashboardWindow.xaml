<Window x:Class="SurtidorADM.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Surtidor de la Frontera - Panel de Control" Height="780" Width="1100" 
        WindowStartupLocation="CenterScreen" Background="#F4F6F9" FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Reutilizamos el estilo de alineación a la derecha si fuera necesario -->
        <Style x:Key="RightAlignStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>

        <!-- Estilo de Botón idéntico al de MainWindow con CornerRadius 8 -->
        <Style x:Key="SurtidorButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <!-- Animación de desvanecimiento (Fade-in) -->
                    <DoubleAnimation Storyboard.TargetName="RootGrid" 
                                     Storyboard.TargetProperty="Opacity" 
                                     From="0" To="1" Duration="0:0:0.5">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <!-- Animación de deslizamiento hacia arriba (Slide-up) -->
                    <DoubleAnimation Storyboard.TargetName="RootTranslation" 
                                     Storyboard.TargetProperty="Y" 
                                     From="40" To="0" Duration="0:0:0.5">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid x:Name="RootGrid" Background="#F4F6F9" Opacity="0">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="RootTranslation" Y="40"/>
        </Grid.RenderTransform>
        <Grid.ColumnDefinitions>
            <!-- Columna del Sidebar igual a MainWindow (300) -->
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- BARRA LATERAL (SIDEBAR) idéntica a la principal -->
        <Border Grid.Column="0" Background="#112A46" CornerRadius="0,20,20,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.2" Direction="320"/>
            </Border.Effect>

            <StackPanel Margin="25">
                <!-- Contenedor del Logo idéntico -->
                <Border Background="White" CornerRadius="12" Padding="15" Margin="0,0,0,30">
                    <Image Source="pack://application:,,,/Assets/surtidor_logo.png" Height="80" Stretch="Uniform"/>
                </Border>

                <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#8A9BB0" Margin="0,0,0,20" Text="REPORTES Y AUDITORÍA"/>

                <!-- Botones del Menú con los mismos estilos y colores que MainWindow -->
                <Button Click="BtnVentas_Click"
                        Height="45" Margin="0,0,0,12" 
                        Background="#294B73" Style="{StaticResource SurtidorButtonStyle}">
                    <TextBlock Text="📄 Resumen Ventas"/>
                </Button>

                <Button Click="BtnConseguidas_Click"
                        Height="45" Margin="0,0,0,12" 
                        Background="#27AE60" Style="{StaticResource SurtidorButtonStyle}">
                    <TextBlock Text="✅ Conseguidas"/>
                </Button>

                <Button Click="BtnNoConseguidas_Click"
                        Height="45" Margin="0,0,0,12" 
                        Background="#C0392B" Style="{StaticResource SurtidorButtonStyle}">
                    <TextBlock Text="❌ No Conseguidas"/>
                </Button>

                <Button Click="BtnSobrantes_Click"
                        Height="45" Margin="0,0,0,12" 
                        Background="#E67E22" Style="{StaticResource SurtidorButtonStyle}">
                    <TextBlock Text="🏦 Sobrantes Banco"/>
                </Button>

                <Button Click="BtnBancoReporte_Click"
                        Height="45" Margin="0,0,0,12" 
                        Background="#16A085" Style="{StaticResource SurtidorButtonStyle}">
                    <TextBlock Text="🏦 Banco"/>
                </Button>

                <Button Click="BtnAuditoria_Click"
                        Height="45" Margin="0,0,0,12" 
                        Background="#8E44AD" Style="{StaticResource SurtidorButtonStyle}">
                    <TextBlock Text="📊 Auditoría Financiera"/>
                </Button>

                <Button Click="BtnReportes_Click"
                        Height="45" Margin="0,0,0,30" 
                        Background="#27AE60" Style="{StaticResource SurtidorButtonStyle}">
                    <TextBlock Text="📊 Reportes Personalizados"/>
                </Button>

                <Separator Background="#294B73" Margin="0,10,0,20" Height="1"/>

                <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#8A9BB0" Margin="0,0,0,10" Text="SISTEMA"/>
                <TextBlock Text="Panel secundario de consultas avanzadas de conciliación." Foreground="#D1D9E2" TextWrapping="Wrap" FontSize="13" LineHeight="18"/>
            </StackPanel>
        </Border>

        <!-- CONTENIDO PRINCIPAL (Columna 1) -->
        <Grid Grid.Column="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Cabecera de Página igual a MainWindow -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Panel de Control y Reportes" FontSize="28" FontWeight="Bold" Foreground="#112A46"/>
                    <TextBlock Text="Visualización de métricas avanzadas y estados de órdenes" FontSize="15" Foreground="#7F8C8D" Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Tarjeta de Búsqueda igual a los bloques de control de MainWindow -->
            <Border Grid.Row="1" Background="White" CornerRadius="12" BorderBrush="#E1E5EA" BorderThickness="1" Padding="15" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Buscar Nro de Orden:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#294B73" FontSize="14"/>
                    
                    <!-- TextBox con estilo limpio y padding -->
                    <TextBox Grid.Column="2" x:Name="txtBusquedaOrden" Height="40" VerticalContentAlignment="Center" Padding="10,5" BorderBrush="#D1D9E2" FontSize="14">
                        <TextBox.Resources>
                            <!-- Esquinas redondeadas para TextBox en WPF -->
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <Button Grid.Column="4" Click="BtnBuscar_Click" Width="150" Height="40" Background="#294B73" Style="{StaticResource SurtidorButtonStyle}">
                        <TextBlock Text="🔍 Buscar Orden"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Tarjeta de Búsqueda por rango de fechas (Desde / Hasta) -->
            <Border Grid.Row="2" Background="White" CornerRadius="12" BorderBrush="#E1E5EA" BorderThickness="1" Padding="15" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Desde:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#294B73" FontSize="14"/>
                    
                    <DatePicker Grid.Column="2" x:Name="dpDesde" Height="40" VerticalContentAlignment="Center" BorderBrush="#D1D9E2" FontSize="14"/>

                    <TextBlock Grid.Column="4" Text="Hasta:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#294B73" FontSize="14"/>
                    
                    <DatePicker Grid.Column="6" x:Name="dpHasta" Height="40" VerticalContentAlignment="Center" BorderBrush="#D1D9E2" FontSize="14"/>

                    <Button Grid.Column="8" Click="BtnBuscarPorFecha_Click" Width="150" Height="40" Background="#294B73" Style="{StaticResource SurtidorButtonStyle}">
                        <TextBlock Text="🔍 Buscar por Fecha"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Fila de Totales de la Búsqueda por Fecha -->
            <Grid Grid.Row="3" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Tarjeta 1: Venta Total USD -->
                <Border Grid.Column="0" Background="#112A46" CornerRadius="12" Padding="15">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.1" Direction="320"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Venta Total USD" Foreground="#A0B2C6" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock x:Name="tbTotalVendido" Text="0.000 $" Foreground="#F39C12" FontSize="20" FontWeight="Bold" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Tarjeta 2: Total Pagado en Caja USD -->
                <Border Grid.Column="2" Background="#1A3A5D" CornerRadius="12" Padding="15">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.1" Direction="320"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Total Pagado Caja USD" Foreground="#A0B2C6" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock x:Name="tbTotalCaja" Text="0.000 $" Foreground="#3498DB" FontSize="20" FontWeight="Bold" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Tarjeta 3: Total Financiado USD -->
                <Border Grid.Column="4" Background="#294B73" CornerRadius="12" Padding="15">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.1" Direction="320"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Total Financiado USD" Foreground="#A0B2C6" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock x:Name="tbTotalFinanciado" Text="0.000 $" Foreground="#27AE60" FontSize="20" FontWeight="Bold" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Fila de Métricas Secundarias de Búsqueda -->
            <Grid Grid.Row="4" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Tarjeta 1: Cuotas y Órdenes Pendientes -->
                <Border Grid.Column="0" Background="#112A46" CornerRadius="12" Padding="15">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.1" Direction="320"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Cuotas y Órdenes Pendientes" Foreground="#A0B2C6" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock x:Name="tbCuotasRestantes" Text="0 cuotas (0 ord.) / 0.000 $" Foreground="#E74C3C" FontSize="17" FontWeight="Bold" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Tarjeta 2: Cuotas Canceladas -->
                <Border Grid.Column="2" Background="#1A3A5D" CornerRadius="12" Padding="15">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.1" Direction="320"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Cuotas Canceladas (Pagado)" Foreground="#A0B2C6" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock x:Name="tbCuotasPagadas" Text="0 cuotas / 0.000 $" Foreground="#2ECC71" FontSize="17" FontWeight="Bold" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Tarjeta 3: Monto que debe Cashea -->
                <Border Grid.Column="4" Background="#294B73" CornerRadius="12" Padding="15">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.1" Direction="320"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Monto que debe Cashea" Foreground="#A0B2C6" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock x:Name="tbDebeCashea" Text="0.000 $" Foreground="#F1C40F" FontSize="20" FontWeight="Bold" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- DataGrid Principal igual a MainWindow -->
            <Border Grid.Row="5" Background="White" CornerRadius="12" BorderBrush="#E1E5EA" BorderThickness="1" ClipToBounds="True">
                <DataGrid x:Name="dgResultados" AutoGenerateColumns="True" 
                          CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="Column" 
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E1E5EA" BorderThickness="0" Background="Transparent"
                          RowHeight="35" Padding="10">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Foreground" Value="#2C3E50"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F2F4F7"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</Window>