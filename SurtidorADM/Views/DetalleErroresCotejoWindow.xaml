<Window x:Class="SurtidorADM.Views.DetalleErroresCotejoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Análisis de Discrepancias y Conciliación" 
        Height="550" Width="850"
        WindowStartupLocation="CenterOwner"
        Background="#F3F4F6"
        FontFamily="Segoe UI, Inter, Roboto">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Header bar -->
            <RowDefinition Height="Auto"/>
            <!-- Content space -->
            <RowDefinition Height="*"/>
            <!-- Action buttons -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 1. Header Bar -->
        <Border Grid.Row="0" Background="#1E3A8A" Padding="20,15">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="🔍" FontSize="26" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <StackPanel>
                    <TextBlock Text="Auditoría de Diferencias del Reporte Mensual" 
                               FontWeight="Bold" FontSize="18" Foreground="White"/>
                    <TextBlock Text="Análisis detallado de variaciones de tasas de cambio (BCV vs Cashea) y discrepancias con el banco." 
                               FontSize="12" Foreground="#93C5FD" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 2. Main Content Grid -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Status Alerts banner -->
            <Border Grid.Row="0" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,15">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="ℹ️" FontSize="16" Foreground="#1E40AF" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Las diferencias menores en el banco se deben a que el sistema usa la tasa oficial BCV diaria para convertir cada abono, mientras que Cashea aplica una tasa consolidada en su corte mensual." 
                               FontSize="11.5" Foreground="#1E40AF" VerticalAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- DataGrid for Anomalies -->
            <Border Grid.Row="1" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="1">
                <DataGrid x:Name="GridDiferencias"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#E5E7EB"
                          BorderThickness="0"
                          Background="White"
                          RowHeight="40"
                          AlternatingRowBackground="#F9FAFB"
                          HeadersVisibility="Column">
                    
                    <!-- Header Custom Style -->
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F3F4F6"/>
                            <Setter Property="Foreground" Value="#374151"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Padding" Value="10,12"/>
                            <Setter Property="BorderBrush" Value="#E5E7EB"/>
                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <!-- Reference -->
                        <DataGridTextColumn Header="Referencia" Binding="{Binding Referencia}" Width="110">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="10,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Foreground" Value="#4B5563"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Date -->
                        <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha}" Width="85">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="8,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Foreground" Value="#4B5563"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Error Type -->
                        <DataGridTextColumn Header="Tipo de Error" Binding="{Binding TipoError}" Width="190">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="10,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="11.5"/>
                                    <Setter Property="Foreground" Value="#C0392B"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Detail Explicativo -->
                        <DataGridTextColumn Header="Detalle de la Discrepancia" Binding="{Binding Detalle}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="10,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                    <Setter Property="FontSize" Value="11.5"/>
                                    <Setter Property="Foreground" Value="#1F2937"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Financial Impact USD -->
                        <DataGridTextColumn Header="Impacto ($)" Binding="{Binding ImpactoUsd}" Width="105">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="0,0,12,0"/>
                                    <Setter Property="TextAlignment" Value="Right"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="12.5"/>
                                    <Setter Property="Foreground" Value="#D35400"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- 3. Bottom Action Bar -->
        <Border Grid.Row="2" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="* Un impacto positivo (+) indica mayor abono bancario recibido del esperado." 
                           VerticalAlignment="Center" FontSize="11" Foreground="#6B7280"/>
                
                <Button Grid.Column="1" Content="Cerrar Diagnóstico" 
                        Click="Cerrar_Click"
                        Width="150" Height="36"
                        Background="#2563EB" Foreground="White"
                        FontWeight="SemiBold" FontSize="12.5"
                         BorderThickness="0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1D4ED8"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
