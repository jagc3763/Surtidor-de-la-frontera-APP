<Window x:Class="SurtidorADM.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Surtidor de la Frontera - Módulo de Conciliación" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="RightAlignStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>
    </Window.Resources>

    <Grid Background="#F4F6F9">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#112A46" CornerRadius="0,20,20,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.2" Direction="320"/>
            </Border.Effect>

            <Grid Margin="25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <Border Background="White" CornerRadius="12" Padding="15" Margin="0,0,0,30">
                        <Image Source="pack://application:,,,/Assets/surtidor_logo.png" Height="80" Stretch="Uniform"/>
                    </Border>

                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#8A9BB0" Margin="0,0,0,20" Text="PANEL DE CONTROL"/>

                    <Border Background="#1A3A5D" CornerRadius="10" Padding="20" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Tasa BCV Oficial (USD)" Foreground="#A0B2C6" FontSize="12" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding TasaBcvActual, StringFormat={}{0:N2} VES}" 
                                       Foreground="#F39C12" FontSize="26" FontWeight="Bold" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <Button Command="{Binding SincronizarBcvCommand}"
                            Height="45" Margin="0,0,0,12" 
                            Background="#E67E22" Foreground="White" FontWeight="Bold" FontSize="14" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="Sincronizar BCV Hoy"/>
                    </Button>

                    <Button Command="{Binding ImportarHistoricoCommand}"
                            Height="45" Margin="0,0,0,30" 
                            Background="#294B73" Foreground="White" FontWeight="SemiBold" FontSize="13" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="Cargar Histórico Excel (.xlsx)"/>
                    </Button>

                    <Button Click="BtnAbrirDashboard_Click"
                            Height="45" Margin="0,0,0,12" 
                            Background="#3498DB" Foreground="White" FontWeight="Bold" FontSize="14" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="10">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="📊 Dashboard de Control" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Command="{Binding LimpiarBaseDatosCommand}"
                            Height="45" Margin="0,0,0,12" 
                            Background="#C0392B" Foreground="White" FontWeight="Bold" FontSize="14" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="🧹 Limpiar Base de Datos"/>
                    </Button>

                    <Separator Background="#294B73" Margin="0,10,0,20" Height="1"/>

                    <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#8A9BB0" Margin="0,0,0,10" Text="ESTADO DEL SISTEMA"/>
                    <TextBlock Text="{Binding MensajeEstado}" Foreground="#D1D9E2" TextWrapping="Wrap" FontSize="13" LineHeight="18"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,15,0,0">
                    <Separator Background="#294B73" Margin="0,0,0,10" Height="1"/>
                    <TextBlock Text="SurtidorADM Versión 1.0.8" Foreground="#8A9BB0" FontSize="11" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                    <Button Content="Buscar Actualizaciones" 
                            Click="BtnBuscarActualizaciones_Click"
                            Height="24" Width="145" Margin="0,5,0,0"
                            Background="#294B73" Foreground="#93C5FD" FontSize="10" FontWeight="SemiBold"
                            BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <TextBlock Text="By JWDIGITAL" Foreground="#5E738F" FontSize="9.5" HorizontalAlignment="Center" FontWeight="Normal" Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Módulo de Conciliación" FontSize="28" FontWeight="Bold" Foreground="#112A46"/>
                    <TextBlock Text="Gestión financiera Cashea y cuentas bancarias" FontSize="15" Foreground="#7F8C8D" Margin="0,5,0,0"/>
                </StackPanel>

                <Button Grid.Column="1" Command="{Binding EjecutarConciliacionCommand}"
                        Height="45" Padding="20,0" Background="#27AE60" Foreground="White" FontWeight="Bold" FontSize="14" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="15,0">
                                    <TextBlock Text="⚙️" Margin="0,0,8,0"/>
                                    <TextBlock Text="Ejecutar Auditoría"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <Border Grid.Row="1" Background="White" CornerRadius="12" BorderBrush="#E1E5EA" BorderThickness="1" Padding="15" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Command="{Binding ImportarPagosCasheaCommand}" Height="40" Background="#F4F6F9" BorderBrush="#D1D9E2" BorderThickness="1" Cursor="Hand" Content="📄 1. Bancos Cashea" FontWeight="SemiBold" Foreground="#294B73"/>
                    <Button Grid.Column="2" Command="{Binding ImportarVentasCasheaCommand}" Height="40" Background="#F4F6F9" BorderBrush="#D1D9E2" BorderThickness="1" Cursor="Hand" Content="📊 2. Ventas Cashea" FontWeight="SemiBold" Foreground="#294B73"/>
                    <Button Grid.Column="4" Command="{Binding ImportarBancoCommand}" Height="40" Background="#EAF2F8" BorderBrush="#AED6F1" BorderThickness="1" Cursor="Hand" Content="🏦 3. Banco Banesco" FontWeight="Bold" Foreground="#154360"/>
                </Grid>
            </Border>
            <TabControl Grid.Row="2" Background="Transparent" BorderThickness="0">
                <!-- Tab 1: Conciliación Individual -->
                <TabItem Header="🔍 Conciliación Individual" FontSize="14" FontWeight="SemiBold" Padding="15,6">
                    <Border Background="White" CornerRadius="0,12,12,12" BorderBrush="#E1E5EA" BorderThickness="1" ClipToBounds="True">
                        <DataGrid ItemsSource="{Binding ResultadosConciliacion}" AutoGenerateColumns="False" 
                                  CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="Column" 
                                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E1E5EA" BorderThickness="0" Background="Transparent"
                                  RowHeight="35" Padding="5">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="Foreground" Value="#2C3E50"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Estatus}" Value="Éxito">
                                            <Setter Property="Background" Value="#EAFAF1"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Estatus}" Value="Falta en Banco">
                                            <Setter Property="Background" Value="#FDEDEC"/>
                                            <Setter Property="Foreground" Value="#C0392B"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Estatus}" Value="Diferencia de Monto">
                                            <Setter Property="Background" Value="#FEF9E7"/>
                                            <Setter Property="Foreground" Value="#D35400"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha, StringFormat=dd/MM/yyyy}" Width="80"/>
                                <DataGridTextColumn Header="Ref. Bancaria" Binding="{Binding Referencia}" Width="100"/>
                                <DataGridTextColumn Header="Cashea ($)" Binding="{Binding MontoCasheaUsd, StringFormat=N2}" Width="100" ElementStyle="{StaticResource RightAlignStyle}"/>
                                <DataGridTextColumn Header="Tasa BCV" Binding="{Binding TasaBcvAplicada, StringFormat=N5}" Width="80" ElementStyle="{StaticResource RightAlignStyle}"/>
                                <DataGridTextColumn Header="Esperado (Bs)" Binding="{Binding MontoEsperadoVes, StringFormat=N2}" Width="120" ElementStyle="{StaticResource RightAlignStyle}"/>
                                <DataGridTextColumn Header="En Banco (Bs)" Binding="{Binding MontoEnBancoVes, StringFormat=N2}" Width="120" ElementStyle="{StaticResource RightAlignStyle}"/>
                                <DataGridTextColumn Header="Diferencia" Binding="{Binding DiferenciaVes, StringFormat=N2}" Width="100" ElementStyle="{StaticResource RightAlignStyle}"/>
                                <DataGridTextColumn Header="Estatus" Binding="{Binding Estatus}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </TabItem>

                <!-- Tab 2: Cotejo de Reporte Mensual -->
                <TabItem Header="📊 Cotejo Reporte Mensual Cashea" FontSize="14" FontWeight="SemiBold" Padding="15,6">
                    <Border Background="White" CornerRadius="0,12,12,12" BorderBrush="#E1E5EA" BorderThickness="1" Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="20"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Cabecera y Botón de Carga -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Cotejo de Totales de Reporte Mensual" FontSize="18" FontWeight="Bold" Foreground="#112A46"/>
                                    <TextBlock Text="{Binding PeriodoCotejo}" FontSize="13" Foreground="#7F8C8D" Margin="0,4,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1" Command="{Binding VerDetallesDiferenciasCommand}" Height="40" Padding="15,0" Background="#3B82F6" Foreground="White" FontWeight="Bold" Cursor="Hand" Visibility="{Binding MostrarPanelCotejo, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,0">
                                                    <TextBlock Text="🔍" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Ver Detalle de Discrepancias"/>
                                                </StackPanel>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Background" Value="#E5E7EB"/>
                                                    <Setter Property="Foreground" Value="#9CA3AF"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#2563EB"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Grid.Column="3" Command="{Binding CargarReporteMensualCommand}" Height="40" Padding="20,0" Background="#16A085" Foreground="White" FontWeight="Bold" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,0">
                                                    <TextBlock Text="📁" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Cargar Reporte Mensual (.xlsx)"/>
                                                </StackPanel>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>

                            <!-- Tabla de Comparación -->
                            <DataGrid Grid.Row="2" ItemsSource="{Binding ItemsCotejo}" AutoGenerateColumns="False"
                                      CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E1E5EA" BorderThickness="0" Background="Transparent"
                                      RowHeight="38" Visibility="{Binding MostrarPanelCotejo, Converter={StaticResource BooleanToVisibilityConverter}}"
                                      MouseDoubleClick="CotejoGrid_MouseDoubleClick">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Background" Value="White"/>
                                        <Setter Property="Foreground" Value="#2C3E50"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Coincide}" Value="True">
                                                <Setter Property="Background" Value="#EAFAF1"/>
                                                <Setter Property="Foreground" Value="#27AE60"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Coincide}" Value="False">
                                                <Setter Property="Background" Value="#FDEDEC"/>
                                                <Setter Property="Foreground" Value="#C0392B"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Concepto Financiero" Binding="{Binding Concepto}" Width="250" FontWeight="SemiBold"/>
                                    <DataGridTextColumn Header="Monto Cashea (Reporte)" Binding="{Binding ValorCashea}" Width="180" ElementStyle="{StaticResource RightAlignStyle}"/>
                                    <DataGridTextColumn Header="Monto Sistema (DB)" Binding="{Binding ValorSistema}" Width="180" ElementStyle="{StaticResource RightAlignStyle}"/>
                                    <DataGridTextColumn Header="Diferencia" Binding="{Binding Diferencia}" Width="150" ElementStyle="{StaticResource RightAlignStyle}"/>
                                    <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </TabItem>

                <!-- Tab 3: Asistente IA -->
                <TabItem Header="💬 Asistente IA" FontSize="14" FontWeight="SemiBold" Padding="15,6">
                    <Border Background="White" CornerRadius="0,12,12,12" BorderBrush="#E1E5EA" BorderThickness="1" Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <!-- Configuration: Key API -->
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="15"/>
                                <!-- Chat history -->
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="15"/>
                                <!-- Input box -->
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Configuration: API Key -->
                            <Border Grid.Row="0" Background="#F8FAFC" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Padding="15,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="15"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="15"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Google Gemini API Key" FontWeight="Bold" Foreground="#1E293B" FontSize="12.5"/>
                                        <TextBlock Text="Requerida para el chat (obténla gratis en Google AI Studio)" Foreground="#64748B" FontSize="11" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <PasswordBox x:Name="PbApiKey" Grid.Column="2" Height="32" Padding="8,0" VerticalAlignment="Center" Background="White" BorderBrush="#CBD5E1" BorderThickness="1"/>
                                    <Button Grid.Column="4" Click="BtnGuardarApiKey_Click" Content="Guardar Clave" Height="32" Padding="15,0" Background="#3B82F6" Foreground="White" FontWeight="Bold" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="12,0"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>

                            <!-- Chat History ScrollViewer -->
                            <Border Grid.Row="2" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Background="#F8FAFC" Padding="10">
                                <ScrollViewer x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding MensajesChat}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,5">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border HorizontalAlignment="{Binding Alineacion}" CornerRadius="12" Padding="12,8" Background="{Binding ColorBurbuja}" MaxWidth="600">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Contenido}" TextWrapping="Wrap" Foreground="{Binding ColorTexto}" FontSize="13.5" LineHeight="18"/>
                                                            <TextBlock Text="{Binding Fecha, StringFormat=hh:mm tt}" FontSize="9.5" Foreground="#94A3B8" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>

                            <!-- Input Box Area -->
                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding MensajeChatTexto, UpdateSourceTrigger=PropertyChanged}" 
                                         KeyDown="TextBoxChat_KeyDown"
                                         Height="40" Padding="12,0" VerticalContentAlignment="Center"
                                         Background="White" BorderBrush="#CBD5E1" BorderThickness="1"
                                         FontSize="13.5">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Style.Resources>
                                                <VisualBrush x:Key="PlaceholderBrush" AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="Escribe tu pregunta sobre conciliación aquí..." Foreground="#94A3B8" FontSize="13.5" Margin="10,0,0,0"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Style.Resources>
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="">
                                                    <Setter Property="Background" Value="{StaticResource PlaceholderBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                <Button Grid.Column="2" Command="{Binding EnviarMensajeChatCommand}" Height="40" Padding="25,0" Background="#10B981" Foreground="White" FontWeight="Bold" FontSize="13.5" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="15,0">
                                                    <TextBlock Text="✈️" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Enviar"/>
                                                </StackPanel>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Grid>
                    </Border>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>