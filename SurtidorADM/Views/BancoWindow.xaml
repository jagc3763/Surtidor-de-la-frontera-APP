<Window x:Class="SurtidorADM.Views.BancoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Surtidor de la Frontera - Reporte de Banco por Período" Height="780" Width="1100" 
        WindowStartupLocation="CenterScreen" Background="#F4F6F9" FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Estilo de Botón con CornerRadius 8 -->
        <Style x:Key="SurtidorButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <!-- Animación de desvanecimiento (Fade-in) -->
                    <DoubleAnimation Storyboard.TargetName="RootGrid" 
                                     Storyboard.TargetProperty="Opacity" 
                                     From="0" To="1" Duration="0:0:0.5">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <!-- Animación de deslizamiento hacia arriba (Slide-up) -->
                    <DoubleAnimation Storyboard.TargetName="RootTranslation" 
                                     Storyboard.TargetProperty="Y" 
                                     From="40" To="0" Duration="0:0:0.5">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid x:Name="RootGrid" Opacity="0">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="RootTranslation" Y="40"/>
        </Grid.RenderTransform>

        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Cabecera de Página -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Módulo Banco - Análisis de Período" FontSize="28" FontWeight="Bold" Foreground="#112A46"/>
                    <TextBlock Text="Consolidado de cobros y abonos bancarios por rango de fechas de compra" FontSize="15" Foreground="#7F8C8D" Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Tarjeta de Búsqueda por rango de fechas (Desde / Hasta) -->
            <Border Grid.Row="1" Background="White" CornerRadius="12" BorderBrush="#E1E5EA" BorderThickness="1" Padding="15" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Desde:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#294B73" FontSize="14"/>
                    
                    <DatePicker Grid.Column="2" x:Name="dpDesde" Height="40" VerticalContentAlignment="Center" BorderBrush="#D1D9E2" FontSize="14"/>

                    <TextBlock Grid.Column="4" Text="Hasta:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#294B73" FontSize="14"/>
                    
                    <DatePicker Grid.Column="6" x:Name="dpHasta" Height="40" VerticalContentAlignment="Center" BorderBrush="#D1D9E2" FontSize="14"/>

                    <Button Grid.Column="8" Click="BtnBuscar_Click" Width="150" Height="40" Background="#16A085" Style="{StaticResource SurtidorButtonStyle}">
                        <TextBlock Text="🔍 Filtrar Banco"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Fila de 4 Tarjetas de Métricas -->
            <Grid Grid.Row="2" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Tarjeta 1: Saldo en Banco (Bs. / $) -->
                <Border Grid.Column="0" Background="#112A46" CornerRadius="12" Padding="15">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.1" Direction="320"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Saldo en Banco (Bs. / $)" Foreground="#A0B2C6" FontSize="11" FontWeight="SemiBold"/>
                        <TextBlock x:Name="tbSaldoBancoBs" Text="0.000 Bs. / 0.000 $" Foreground="#F39C12" FontSize="14" FontWeight="Bold" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Tarjeta 2: Órdenes Pagadas -->
                <Border Grid.Column="2" Background="#1A3A5D" CornerRadius="12" Padding="15">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.1" Direction="320"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Órdenes Pagadas (Bs. / $)" Foreground="#A0B2C6" FontSize="11" FontWeight="SemiBold"/>
                        <TextBlock x:Name="tbOrdenesPagadasBs" Text="0 ord. / 0.000 Bs. / 0.000 $" Foreground="#2ECC71" FontSize="13" FontWeight="Bold" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Tarjeta 3: Órdenes Pendientes -->
                <Border Grid.Column="4" Background="#294B73" CornerRadius="12" Padding="15">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.1" Direction="320"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Órdenes Pendientes" Foreground="#A0B2C6" FontSize="11" FontWeight="SemiBold"/>
                        <TextBlock x:Name="tbOrdenesPendientesUsd" Text="0 ord. / 0.000 $" Foreground="#E74C3C" FontSize="14" FontWeight="Bold" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Tarjeta 4: Esperado en Banco -->
                <Border Grid.Column="6" Background="#2C3E50" CornerRadius="12" Padding="15">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.1" Direction="320"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Esperado en Banco" Foreground="#A0B2C6" FontSize="11" FontWeight="SemiBold"/>
                        <TextBlock x:Name="tbEsperadoBancoUsd" Text="0.000 $" Foreground="#3498DB" FontSize="16" FontWeight="Bold" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- DataGrid Principal -->
            <Border Grid.Row="3" Background="White" CornerRadius="12" BorderBrush="#E1E5EA" BorderThickness="1" ClipToBounds="True">
                <DataGrid x:Name="dgResultados" AutoGenerateColumns="True" 
                          CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="Column" 
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E1E5EA" BorderThickness="0" Background="Transparent"
                          RowHeight="35" Padding="10">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Foreground" Value="#2C3E50"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F2F4F7"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</Window>
